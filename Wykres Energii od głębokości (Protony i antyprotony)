import numpy as np
import matplotlib.pyplot as plt
from matplotlib.widgets import Slider
from scipy.ndimage import gaussian_filter1d

# --- PARAMETRY FIZYCZNE ---
alpha = 0.0022  
p = 1.77        
x = np.linspace(0, 30, 1000)

def calculate_energy_release(E0, is_antiproton=False):
    """
    Oblicza lokalnie zdeponowaną energię. 
    Podstawą jest elektromagnetyczne dE/dx z odwróconego równania Bragga-Kleemana.
    Dla antyprotonu dodawana jest energia z gwiazdy anihilacyjnej.
    """
    R = alpha * (E0 ** p)
    dedx = np.zeros_like(x)
    
    const = 1.0 / (p * (alpha ** (1.0 / p)))
    exponent = (1.0 - p) / p 
    
    for i, xi in enumerate(x):
        if xi < R - 0.08:
            dedx[i] = const * ((R - xi) ** exponent)
        elif xi >= R - 0.08 and xi < R + 0.1:
            dedx[i] = dedx[i-1] * 1.1 if i > 0 else 0

    straggling_sigma = max(2, int(R * 0.8)) 
    dedx = gaussian_filter1d(dedx, sigma=straggling_sigma)
    
    if is_antiproton:
        # Symulacja potężnego zdeponowania energii jądrowej z ciężkich fragmentów
        sigma_wybuchu = 0.15 + (R / 120.0)
        # Amplituda ustawiona na ok. 80-100 MeV/cm (znacznie przewyższa klasyczny pik)
        amplituda_wybuchu = 90.0 * (1 - (R / 60.0))
        dodatkowa_energia = amplituda_wybuchu * np.exp(-0.5*((x - R)/sigma_wybuchu)**2)
        dedx += dodatkowa_energia
        
    return dedx, R

# --- KONFIGURACJA OKNA ---
fig, ax = plt.subplots(figsize=(12, 8))
fig.canvas.manager.set_window_title('Zdolność Hamowania: Proton vs Antyproton')
plt.subplots_adjust(bottom=0.25) # Miejsce na suwak

# Inicjalne linie na jednym wykresie
line_p, = ax.plot(x, np.zeros_like(x), color='blue', lw=2.5, label='Klasyczne Protony (Tylko dE/dx)')
line_a, = ax.plot(x, np.zeros_like(x), color='red', lw=2.5, linestyle='--', label='Antyprotony (dE/dx + Anihilacja)')

# Pionowa linia oznaczająca całkowity zasięg
vline_R = ax.axvline(x=0, color='gray', linestyle=':', label='Całkowity Zasięg')

# Ustawienia estetyczne osi
ax.set_xlim(0, 30)
ax.set_xlabel('Głębokość w tkance $x$ [cm]', fontsize=11)
ax.set_ylabel('Lokalnie oddana energia $S = -dE/dx$ [MeV/cm]', fontsize=11)
ax.set_title("Zdolność Hamowania: Protony vs Antyprotony", fontweight='bold', fontsize=14)
ax.grid(True, linestyle='--', alpha=0.6)
ax.legend(loc='upper left', fontsize=11)

# --- SUWAK (WIDGET) ---
axcolor = 'lightgrey'
ax_slider_E = plt.axes([0.15, 0.1, 0.7, 0.04], facecolor=axcolor)
slider_E = Slider(ax_slider_E, 'Energia $E_0$ [MeV]', 50.0, 250.0, valinit=150.0, color='purple')

# --- LOGIKA AKTUALIZACJI ---
def update(val):
    E0 = slider_E.val
    
    # Obliczenia dla obu cząstek
    dedx_p, R = calculate_energy_release(E0, is_antiproton=False)
    dedx_a, R = calculate_energy_release(E0, is_antiproton=True)
    
    # Aktualizacja linii
    line_p.set_ydata(dedx_p)
    line_a.set_ydata(dedx_a)
    
    vline_R.set_xdata([R, R])
    vline_R.set_label(f'Całkowity Zasięg: {R:.2f} cm')
    
    # DYNAMICZNE SKALOWANIE OSI Y
    # Skalujemy do wyższego piku (zawsze antyprotonu), żeby oba wykresy się zmieściły
    ax.set_ylim(0, max(dedx_a) * 1.1)
    
    # Odświeżenie legendy, aby zaktualizować wartość zasięgu
    ax.legend(loc='upper left', fontsize=11)
    
    fig.canvas.draw_idle()

# Podpięcie zdarzenia
slider_E.on_changed(update)

# Wywołanie dla wartości początkowej
update(slider_E.val)

plt.show()